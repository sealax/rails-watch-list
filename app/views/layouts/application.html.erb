<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Watch List" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rails Watch List">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="app-navbar">
      <div class="container app-navbar__inner">
        <%= link_to root_path, class: "app-navbar__brand" do %>
          <span class="app-navbar__mark"><i class="fa-solid fa-clapperboard"></i></span>
          <span>Watch List</span>
        <% end %>

        <div class="app-navbar__actions">
          <%= link_to "My Lists", lists_path, class: "app-navbar__link" %>
          <%= link_to new_list_path, class: "btn btn-primary btn-sm" do %>
            <i class="fa-solid fa-plus"></i>
            <span>New List</span>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice.present? || alert.present? %>
      <div class="flash-wrap container">
        <% if notice.present? %>
          <div class="alert alert-success app-alert" role="alert"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger app-alert" role="alert"><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <main class="app-shell">
      <%= yield %>
    </main>
  </body>
</html>
