<section class="home-hero">
  <div class="container home-hero__content">
    <p class="eyebrow">Curated movie nights</p>
    <h1>Save movies into lists worth coming back to.</h1>
    <p class="home-hero__copy">Build collections for genres, moods, trips, date nights, or the classics you always recommend.</p>
    <%= link_to new_list_path, class: "btn btn-primary btn-lg" do %>
      <i class="fa-solid fa-plus"></i>
      <span>Create list</span>
    <% end %>
  </div>
</section>

<div class="container content-section">
  <div class="section-header">
    <div>
      <p class="eyebrow">Library</p>
      <h2>My Lists</h2>
    </div>
    <span class="section-header__meta"><%= pluralize(@lists.count, "list") %></span>
  </div>

  <% if @lists.any? %>
    <div class="list-grid">
    <% @lists.each do |list| %>
      <div class="list-card-wrap">
        <%= link_to list_path(list), class: "list-card", style: "--list-image: url('#{list.photo.attached? ? url_for(list.photo) : "https://images.unsplash.com/photo-1485846234645-a62644f84728"}');" do %>
          <span class="list-card__count"><%= pluralize(list.movies.count, "movie") %></span>
          <h3><%= list.name %></h3>
          <span class="list-card__cta">Open list</span>
        <% end %>

        <%= button_to list_path(list),
          method: :delete,
          data: { turbo_confirm: "Delete this list?" },
          class: "icon-action icon-action--danger",
          aria: { label: "Delete #{list.name}" } do %>
          <i class="fa-solid fa-trash-can"></i>
        <% end %>
      </div>
    <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <i class="fa-solid fa-film"></i>
      <h3>No lists yet</h3>
      <p>Create your first watch list and start organizing movies by mood, genre, or occasion.</p>
      <%= link_to "Create a list", new_list_path, class: "btn btn-primary" %>
    </div>
  <% end %>

</div>
