<h1>These are the Lists</h1>

<% @lists.each do |list| %>
  <div class="card mb-3">
    <div class="card-body">
      <h5 class="card-title"><%= link_to list.name, list_path(list) %></h5>
      <p class="card-text"><%= list.bookmarks.count %> bookmark(s)</p>
    </div>
  </div>
<% end %>

<%= link_to "Create New List", new_list_path, class: "btn btn-primary" %>
