<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @list.name %></h1>
    <%= link_to "Back to Lists", lists_path, class: "btn btn-secondary" %>
  </div>

  <% if @list.photo.attached? %>
    <div class="mb-4">
      <%= image_tag @list.photo, class: "img-fluid rounded mb-4", style: "max-height: 300px; width: 100%; object-fit: cover;" %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= render "bookmarks/form", bookmark: Bookmark.new, list: @list %>
  </div>

  <div class="row">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="col-md-4">
        <div class="movie-card mb-4">

          <%= image_tag bookmark.movie.backdrop_url %>

          <div class="card-body">
            <h5 class="card-title"><%= bookmark.movie.title %></h5>
            <p class="card-text"><%= bookmark.comment %></p>

            <%= button_to "Delete",
              bookmark_path(bookmark),
              method: :delete,
              data: { turbo_confirm: "Are you sure?" },
              class: "btn btn-danger btn-sm mt-2" %>
          </div>

        </div>
      </div>
    <% end %>
  </div>

</div>
